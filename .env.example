# Ollama lokal
OLLAMA_HOST=http://127.0.0.1:11434
CHAT_MODEL=gemma3:4b
VISION_MODEL=gemma3:4b
CLASSIFIER_MODEL=gemma3:4b

# Kalau punya API key Ollama Web Search, isi ini. Kalau kosong, bot pakai fallback Bing RSS.
OLLAMA_API_KEY=

# Stable Diffusion WebUI / Forge API. Jalankan WebUI dengan --api.
SD_WEBUI_URL=http://127.0.0.1:7860
SD_WIDTH=768
SD_HEIGHT=768
SD_STEPS=20

# Bot
BOT_NAME=AI LUKY
STICKER_AUTHOR=AI LUKY
STICKER_NAME=AI LUKY
AUTO_REPLY=false
AUTO_MEMORY=true
MAX_DOWNLOAD_MB=50

# Kirim/reply gambar lalu tanya biasa agar AI langsung melihat gambar
AUTO_IMAGE=true

# true hanya untuk debug kalau kamu tes dari nomor bot sendiri. Bisa membuat bot merespons pesan sendiri.
DEBUG_ACCEPT_FROM_ME=false

# Zona waktu untuk AI mengetahui jam/hari/tanggal
TIMEZONE=Asia/Jakarta

# Memori percakapan natural: AI bisa lanjut obrolan/curhat tapi tetap bisa ganti topik
CONVERSATION_MEMORY=true

# Stable Diffusion WebUI / Forge API
IMAGE_API=http://127.0.0.1:7860
IMAGE_WIDTH=512
IMAGE_HEIGHT=512
IMAGE_STEPS=20
IMAGE_CFG=7
IMAGE_SAMPLER=Euler a
IMAGE_TIMEOUT=300000

# Smart image prompt enhancer
SMART_IMAGE_PROMPT=true
IMAGE_PROMPT_SEARCH=true

# Internet search mode: conservative | aggressive | always
AUTO_SEARCH_MODE=smart
# true = bot kirim pesan saat sedang auto-search
SEARCH_ANNOUNCE=false

# Generate video sederhana dari Stable Diffusion frames + ffmpeg
SMART_VIDEO_PROMPT=true
VIDEO_PROMPT_SEARCH=true
VIDEO_WIDTH=512
VIDEO_HEIGHT=512
VIDEO_FRAMES=8
VIDEO_FPS=4
VIDEO_STEPS=12
VIDEO_CFG=7
VIDEO_SAMPLER=Euler a
VIDEO_SUBSEED_STRENGTH=0.18
VIDEO_IMAGE_TIMEOUT=300000

VIDEO_MOTION_MODE=panzoom
VIDEO_SECONDS=4
VIDEO_OUTPUT_FPS=24
VIDEO_ZOOM_SPEED=0.0018
# ComfyUI AnimateDiff API untuk command !animasi
COMFY_URL=http://127.0.0.1:8188
COMFY_WORKFLOW=workflows/animatediff-api.json
COMFY_WIDTH=320
COMFY_HEIGHT=320
COMFY_FRAMES=8
COMFY_FPS=8
COMFY_STEPS=8
COMFY_CFG=6
COMFY_TIMEOUT=1800000
COMFY_POLL_MS=2000
COMFY_NEGATIVE=deformed car, broken car, missing wheels, extra wheels, distorted vehicle, malformed body, abstract shape, blurry, low quality, watermark, text, logo, bad anatomy, deformed person, extra limbs, cropped subject
# Kalau auto patch prompt salah node, isi ID node dari workflow API:
# COMFY_POSITIVE_NODE=
# COMFY_NEGATIVE_NODE=
# COMFY_LATENT_NODE=
# COMFY_KSAMPLER_NODE=
# COMFY_VIDEO_NODE=

COMFY_HISTORY_HTTP_TIMEOUT=180000
COMFY_PROMPT_HTTP_TIMEOUT=120000
COMFY_VIEW_HTTP_TIMEOUT=180000
